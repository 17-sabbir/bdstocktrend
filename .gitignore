# =============================
bdstocktrend-forecasting-engine-prophet/data/
bdstocktrend-forecasting-engine-prophet/__pycache__/
bdstocktrend-forecasting-engine-prophet/.pytest_cache/
bdstocktrend-forecasting-engine-prophet/.mypy_cache/
bdstocktrend-forecasting-engine-prophet/.ruff_cache/
bdstocktrend-forecasting-engine-prophet/.venv/
bdstocktrend-forecasting-engine-prophet/venv/
